{
  "name": "edutrack-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "lint": "npm --prefix frontend run lint",
    "install-all": "npm install && npm --prefix frontend install",
    "db:push": "npm --prefix frontend run db:push",
    "db:generate": "npm --prefix frontend run db:generate",
    "postinstall": "npm --prefix frontend install"
  }
}
